# TheBotCompany runner settings
TBC_HOME=~/.hpc_agent
TBC_PASSWORD=

# HPC backend
HPC_BACKEND_URL=http://localhost:5328

# HPC polling (ms between status checks while agent waits)
HPC_POLL_INTERVAL_MS=30000
# Max poll attempts (720 * 30s = 6 hours)
HPC_POLL_MAX_ATTEMPTS=720

# API keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
