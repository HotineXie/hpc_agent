# Flask
FLASK_ENV=development
FLASK_PORT=5328

# Database (SQLite by default, single-user local)
DATABASE_URL=sqlite:///hpc_agent.db

# Globus Compute auth
# Option 1: Use native credential store (~/.globus_compute/) — leave blank
# Option 2: Provide access token directly
GLOBUS_COMPUTE_TOKEN=

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
