# ── HPC Agent — root .env.example ─────────────────────────────────────────────
# Copy to .env and fill in values before starting services.

# ── Backend ───────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=5328
DATABASE_URL=sqlite:///hpc_agent.db
FRONTEND_URL=http://localhost:5173

# Globus Compute auth (leave blank to use native credential store)
GLOBUS_COMPUTE_TOKEN=

# ── Runner ────────────────────────────────────────────────────────────────────
HPC_BACKEND_URL=http://localhost:5328
HPC_POLL_INTERVAL_MS=30000

# At least one LLM key required
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional: password to protect the TBC UI (leave blank for no auth)
TBC_PASSWORD=
